{
  "name": "m4d-client",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "yarn type-check && yarn build-only",
    "full-build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile=reports/junit.xml",
    "test:ui": "vitest --ui --api 9527",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint --fix src",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "axios": "^1.18.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.45.6",
    "date-fns": "^4.4.0",
    "focus-trap": "^8.2.1",
    "jquery": "^4.0.0",
    "jquery-validation": "^1.22.1",
    "jquery-validation-unobtrusive": "^4.0.0",
    "markdowndeep": "^1.6.12",
    "typedjson": "^1.8.0",
    "uuid": "^14.0.0",
    "vue": "^3.5.38",
    "vue-showdown": "^4.2.0"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@tsconfig/node18": "^18.2.6",
    "@types/bootstrap": "^5.2.11",
    "@types/jquery": "^4.0.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/utils": "^8.61.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vitest/ui": "^4.1.9",
    "@vue/compiler-dom": "^3.5.38",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/server-renderer": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "fast-glob": "^3.3.3",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.16",
    "vite-plugin-inspect": "^11.4.1",
    "vite-plugin-mkcert": "^2.1.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "resolutions": {
    "strip-ansi": "6.0.1",
    "string-width": "4.2.2",
    "wrap-ansi": "7.0.0"
  },
  "packageManager": "yarn@4.9.2"
}

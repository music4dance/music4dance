@using m4d.ViewModels
@using Azure.Search.Documents.Indexes.Models
@model m4dModels.RawSearch

@{
    ViewBag.Title = "Raw Search";
    ViewBag.BreadCrumbs = BreadCrumbItem.BuildSongLibraryTrail(ViewBag.Title);
}

<div class="py-3">
    <h1 class="mb-4">@ViewBag.Title</h1>

    <div class="card mb-4">
        <div class="card-body p-4">
            <form asp-action="RawSearch" asp-controller="Song" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row mb-3 align-items-start">
                    <label asp-for="SearchText" class="col-sm-3 col-lg-2 col-form-label"></label>
                    <div class="col-sm-9 col-lg-10">
                        <input asp-for="SearchText" class="form-control" />
                        <span asp-validation-for="SearchText" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-start">
                    <label asp-for="ODataFilter" class="col-sm-3 col-lg-2 col-form-label"></label>
                    <div class="col-sm-9 col-lg-10">
                        <input asp-for="ODataFilter" class="form-control" />
                        <span asp-validation-for="ODataFilter" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-start">
                    <label asp-for="SortFields" class="col-sm-3 col-lg-2 col-form-label"></label>
                    <div class="col-sm-9 col-lg-10">
                        <input asp-for="SortFields" class="form-control" />
                        <span asp-validation-for="SortFields" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-start">
                    <label asp-for="SearchFields" class="col-sm-3 col-lg-2 col-form-label"></label>
                    <div class="col-sm-9 col-lg-10">
                        <input asp-for="SearchFields" class="form-control" />
                        <span asp-validation-for="SearchFields" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-start">
                    <label asp-for="Description" class="col-sm-3 col-lg-2 col-form-label"></label>
                    <div class="col-sm-9 col-lg-10">
                        <input asp-for="Description" class="form-control" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3 align-items-start">
                    <label class="col-sm-3 col-lg-2 col-form-label">Cruft Filter</label>
                    <div class="col-sm-9 col-lg-10">
                        <div class="form-check">
                            <input asp-for="ExcludePublishers" class="form-check-input" />
                            <label asp-for="ExcludePublishers" class="form-check-label"></label>
                        </div>
                        <div class="form-check">
                            <input asp-for="ExcludeDances" class="form-check-input" />
                            <label asp-for="ExcludeDances" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="row mb-4 align-items-start">
                    <div class="col-sm-3 col-lg-2"></div>
                    <div class="col-sm-9 col-lg-10">
                        <div class="form-check">
                            <input asp-for="IsLucene" class="form-check-input" />
                            <label asp-for="IsLucene" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-9 col-lg-10 offset-sm-3 offset-lg-2">
                        <button id="submit-search" class="btn btn-primary" type="submit">
                            Search <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (ViewData.ContainsKey("AzureIndexInfo"))
    {
        var index = (SearchIndex)ViewBag.AzureIndexInfo;
        var simpleFields = index.Fields.Where(f => f.Type != SearchFieldDataType.Complex).ToList();

        // Each dance_{id} field (including dance_ALL) is a complex type with the same sub-field
        // shape; group by that shape rather than repeating it once per dance.
        var complexGroups = index.Fields
            .Where(f => f.Type == SearchFieldDataType.Complex)
            .GroupBy(f => string.Join(
                "|",
                f.Fields.Select(sf => $"{sf.Name}:{sf.Type}:{sf.IsSearchable}:{sf.IsSortable}:{sf.IsFilterable}:{sf.IsFacetable}")))
            .Select(g => new
            {
                Ids = g.Select(f => f.Name.StartsWith("dance_") ? f.Name["dance_".Length..] : f.Name)
                    .OrderBy(id => id).ToList(),
                SubFields = g.First().Fields
            })
            .ToList();

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Azure Search Fields</h5>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Datatype</th>
                                <th>Searchable</th>
                                <th>Sortable</th>
                                <th>Filterable</th>
                                <th>Facetable</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var field in simpleFields)
                            {
                                <tr>
                                    <td>@field.Name</td>
                                    <td>@field.Type</td>
                                    <td>@field.IsSearchable</td>
                                    <td>@field.IsSortable</td>
                                    <td>@field.IsFilterable</td>
                                    <td>@field.IsFacetable</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @foreach (var group in complexGroups)
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        Per-Dance Sub-Fields <small class="text-muted">(substitute <code>{id}</code> below)</small>
                    </h5>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Field</th>
                                    <th>Datatype</th>
                                    <th>Searchable</th>
                                    <th>Sortable</th>
                                    <th>Filterable</th>
                                    <th>Facetable</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sub in group.SubFields)
                                {
                                    <tr>
                                        <td>dance_{id}/@sub.Name</td>
                                        <td>@sub.Type</td>
                                        <td>@sub.IsSearchable</td>
                                        <td>@sub.IsSortable</td>
                                        <td>@sub.IsFilterable</td>
                                        <td>@sub.IsFacetable</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted small mb-0"><code>{id}</code> is any of: @string.Join(", ", group.Ids)</p>
                </div>
            </div>
        }
    }
</div>

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "Azure.Core": "Warning",
      "Vite.AspNetCore.TagHelpers.ViteTagHelper": "Error"
    },
    "AzureAppServicesFile": {
      "LogLevel": {
        "Default": "Information",
        "Azure.Core": "Warning",
        "Azure.Identity": "Warning",
        "Vite.AspNetCore.TagHelpers.ViteTagHelper": "Error"
      }
    },
    "AzureAppServicesBlob": {
      "LogLevel": {
        "Default": "Information",
        "Azure.Core": "Warning",
        "Azure.Identity": "Warning",
        "Vite.AspNetCore.TagHelpers.ViteTagHelper": "Error"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DanceMusicContextConnection": "Server=(localdb)\\mssqllocaldb;Database=m4d;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "AppConfig": {
    "Endpoint": "https://music4dance.azconfig.io"
  },
  "SongIndexProd-2": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-prod-2"
  },
  "SongIndexProd-3": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-prod-3"
  },
  "SongIndexTest-2": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-test-2"
  },
  "SongIndexTest-3": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-test-3"
  },
  "SongIndexExperimental": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-experimental"
  },
  "PageIndex": {
    "endpoint": "https://m4d.search.windows.net",
    "indexname": "pages"
  },
  "Vite": {
    "Base": "vclient",
    "PackageManager": "yarn",
    "PackageDirectory": "ClientApp",
    "IgnoreMissingAssets": true
  },
  "UsageTracking": {
    "Enabled": true,
    "AnonymousThreshold": 3,
    "AnonymousBatchSize": 5,
    "AuthenticatedBatchSize": 1,
    "MaxQueueSize": 100
  },
  "EngagementOffcanvas": {
    "Enabled": true,
    "ShowForAnonymous": true,
    "ShowForLoggedIn": true,
    "FirstShowPageCount": 2,
    "RepeatInterval": 5,
    "SessionDismissalTimeout": 5,
    "Messages": {
      "Level1": "<p>Exploring music4dance? We're glad you're here! Create a <strong>free account</strong> to save your searches, build playlists, and get the most out of the site.</p>",
      "Level2": "<p>Still searching for music? We've noticed you're using the site quite a bit. A <strong>free account</strong> lets you tag songs, save searches, and organize your favorites.</p>",
      "Level3": "<p>You're clearly finding music4dance useful for your dance music needs! Consider creating a <strong>free account</strong> to unlock even more features.</p>",
      "LoggedInUpgrade": "<p>Upgrade to <strong>Premium membership</strong> to unlock advanced features and support the music4dance community. Your subscription helps cover hosting costs and keeps the site running for everyone.</p>"
    },
    "PremiumBenefits": {
      "Items": [
        "<a href='https://music4dance.blog/music4dance-help/subscriptions/' target='_blank'>Ad-free experience</a>",
        "<a href='https://music4dance.blog/music4dance-help/playing-or-purchasing-songs/spotify-playlist/' target='_blank'>Spotify playlist integration</a>",
        "<a href='https://music4dance.blog/music4dance-help/bonus-content/' target='_blank'>Bonus content access</a>",
        "Priority email support"
      ],
      "MoreText": "...and more!",
      "CompleteListUrl": "https://music4dance.blog/music4dance-help/subscriptions/"
    },
    "CtaUrls": {
      "Register": "/identity/account/register",
      "Login": "/identity/account/login",
      "Subscribe": "/home/contribute",
      "Features": "https://music4dance.blog/music4dance-help/subscriptions/"
    }
  },
  "RateLimiting": {
    "MaxRequestsPerWindow": 10,
    "WindowMinutes": 1,
    "GlobalMaxRequestsPerWindow": 100,
    "GlobalWindowMinutes": 1,
    "CaptchaThresholdPercent": 20
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "Azure.Core": "Warning",
      "Vite.AspNetCore.TagHelpers.ViteTagHelper": "Error"
    },
    "AzureAppServicesFile": {
      "LogLevel": {
        "Default": "Information",
        "Azure.Core": "Warning",
        "Azure.Identity": "Warning",
        "Vite.AspNetCore.TagHelpers.ViteTagHelper": "Error"
      }
    },
    "AzureAppServicesBlob": {
      "LogLevel": {
        "Default": "Information",
        "Azure.Core": "Warning",
        "Azure.Identity": "Warning",
        "Vite.AspNetCore.TagHelpers.ViteTagHelper": "Error"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DanceMusicContextConnection": "Server=(localdb)\\mssqllocaldb;Database=m4d;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "AppConfig": {
    "Endpoint": "https://music4dance.azconfig.io"
  },
  "SongIndexProd-2": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-prod-2"
  },
  "SongIndexProd-3": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-prod-3"
  },
  "SongIndexTest-2": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-test-2"
  },
  "SongIndexTest-3": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-test-3"
  },
  "SongIndexExperimental": {
    "endpoint": "https://music4dance.search.windows.net",
    "indexname": "songs-experimental"
  },
  "PageIndex": {
    "endpoint": "https://m4d.search.windows.net",
    "indexname": "pages"
  },
  "Vite": {
    "Base": "vclient",
    "PackageManager": "yarn",
    "PackageDirectory": "ClientApp",
    "IgnoreMissingAssets": true
  },
  "UsageTracking": {
    "Enabled": true,
    "AnonymousThreshold": 3,
    "AnonymousBatchSize": 5,
    "AuthenticatedBatchSize": 1,
    "MaxQueueSize": 100
  },
  "EngagementOffcanvas": {
    "Enabled": true,
    "FirstShowPageCount": 2,
    "RepeatInterval": 5,
    "SessionDismissalTimeout": 1,
    "Messages": {
      "Level1": "<h4>Welcome to music4dance!</h4><p>The core service is <strong>free</strong>, but costs money to run. Create a <strong>free account</strong> to save your searches and build playlists.</p>",
      "Level2": "<h4>Still exploring?</h4><p>If you find this site useful, please consider <strong>subscribing</strong> to help keep it running. Your contribution covers hosting and gives you access to <a href='https://music4dance.blog/music4dance-help/subscriptions/'>exclusive features</a>.</p>",
      "Level3": "<h4>Thank you for using music4dance!</h4><p>This site is supported by user subscriptions. If you find it valuable, please <strong>consider subscribing</strong> to help cover hosting costs and keep it running for everyone.</p>"
    },
    "CtaUrls": {
      "Register": "/identity/account/register",
      "Subscribe": "/home/contribute",
      "Features": "https://music4dance.blog/music4dance-help/subscriptions/"
    }
  },
  "RateLimiting": {
    "MaxRequestsPerWindow": 10,
    "WindowMinutes": 1,
    "GlobalMaxRequestsPerWindow": 100,
    "GlobalWindowMinutes": 1,
    "CaptchaThresholdPercent": 20
  }
}
